{
  "name": "gazemotion-vscode",
  "displayName": "GazeMotion",
  "description": "Gaze, two-hand gesture, and voice control for agentic coding workflows.",
  "version": "0.1.1",
  "publisher": "gazemotion",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/zhe-jac/hackthe6ix.git",
    "directory": "editors/vscode"
  },
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Other",
    "Machine Learning"
  ],
  "extensionKind": [
    "ui"
  ],
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": false,
      "description": "Voice requests can ask an agent to modify and execute workspace code."
    },
    "virtualWorkspaces": false
  },
  "activationEvents": [
    "onStartupFinished",
    "onCommand:gazemotion.startBridge",
    "onCommand:gazemotion.stopBridge"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "gazemotion.startBridge",
        "title": "GazeMotion: Start IDE Bridge"
      },
      {
        "command": "gazemotion.stopBridge",
        "title": "GazeMotion: Stop IDE Bridge"
      },
      {
        "command": "gazemotion.nextChange",
        "title": "GazeMotion: Next Captured Change"
      },
      {
        "command": "gazemotion.previousChange",
        "title": "GazeMotion: Previous Captured Change"
      },
      {
        "command": "gazemotion.cancel",
        "title": "GazeMotion: Cancel Pending Action"
      }
    ],
    "configuration": {
      "title": "GazeMotion",
      "properties": {
        "gazemotion.bridge.host": {
          "type": "string",
          "default": "127.0.0.1",
          "description": "Loopback host used by the local GazeMotion bridge."
        },
        "gazemotion.bridge.port": {
          "type": "number",
          "default": 8765,
          "minimum": 1,
          "maximum": 65535,
          "description": "Loopback port used by the local GazeMotion bridge."
        },
        "gazemotion.bridge.sessionToken": {
          "type": "string",
          "default": "",
          "scope": "machine",
          "description": "Optional token that must match the Python IDE configuration."
        },
        "gazemotion.bridge.maxMessageBytes": {
          "type": "number",
          "default": 262144,
          "minimum": 1024,
          "maximum": 1048576,
          "description": "Maximum accepted bridge notification size."
        },
        "gazemotion.agent.command": {
          "type": "string",
          "default": "code",
          "scope": "machine",
          "description": "VS Code CLI executable used to submit agent requests."
        },
        "gazemotion.agent.mode": {
          "type": "string",
          "default": "agent",
          "description": "Agent mode passed to the VS Code CLI chat command."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p tsconfig.json",
    "check-types": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --max-warnings=0",
    "format:check": "prettier --check src package.json tsconfig.json eslint.config.mjs",
    "test": "npm run compile && node --test dist/test/*.test.js",
    "package": "npm run compile && vsce package --out gazemotion-vscode.vsix",
    "verify": "npm run check-types && npm run lint && npm run format:check && npm test"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/vscode": "^1.95.0",
    "@vscode/vsce": "^3.9.2",
    "eslint": "^9.17.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.18.0"
  }
}
