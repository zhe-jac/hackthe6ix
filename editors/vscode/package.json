{
  "name": "chudvis-vscode",
  "displayName": "Chudvis",
  "description": "Wake-word voice navigation, explanations, and bounded code edits for VS Code.",
  "version": "0.3.5",
  "publisher": "chudvis",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/zhe-jac/hackthe6ix.git",
    "directory": "editors/vscode"
  },
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Other",
    "Machine Learning"
  ],
  "extensionKind": [
    "ui"
  ],
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": false,
      "description": "Chudvis sends selected workspace context to a configured provider and can apply validated text edits."
    },
    "virtualWorkspaces": false
  },
  "activationEvents": [
    "onStartupFinished",
    "onView:chudvis.sidebar",
    "onCommand:chudvis.toggle",
    "onCommand:chudvis.startBridge",
    "onCommand:chudvis.stopBridge"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "chudvis",
          "title": "Chudvis",
          "icon": "resources/chudvis.svg"
        }
      ]
    },
    "views": {
      "chudvis": [
        {
          "id": "chudvis.sidebar",
          "name": "Voice Assistant",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "chudvis.toggle",
        "title": "Chudvis: Toggle Controls"
      },
      {
        "command": "chudvis.start",
        "title": "Chudvis: Start Gaze, Gesture, and Voice Controls"
      },
      {
        "command": "chudvis.stop",
        "title": "Chudvis: Stop Gaze, Gesture, and Voice Controls"
      },
      {
        "command": "chudvis.calibrate",
        "title": "Chudvis: Calibrate Gaze"
      },
      {
        "command": "chudvis.testTracking",
        "title": "Chudvis: Test Tracking Safely"
      },
      {
        "command": "chudvis.startBridge",
        "title": "Chudvis: Start IDE Bridge"
      },
      {
        "command": "chudvis.stopBridge",
        "title": "Chudvis: Stop IDE Bridge"
      },
      {
        "command": "chudvis.nextChange",
        "title": "Chudvis: Next Captured Change"
      },
      {
        "command": "chudvis.previousChange",
        "title": "Chudvis: Previous Captured Change"
      },
      {
        "command": "chudvis.cancel",
        "title": "Chudvis: Cancel Pending Action"
      },
      {
        "command": "chudvis.configureBackboardKey",
        "title": "Chudvis: Configure Backboard API Key"
      },
      {
        "command": "chudvis.clearBackboardKey",
        "title": "Chudvis: Clear Backboard API Key"
      },
      {
        "command": "chudvis.clearEditingMemory",
        "title": "Chudvis: Clear Editing Memory"
      },
      {
        "command": "chudvis.openChanges",
        "title": "Chudvis: Open Changes"
      },
      {
        "command": "chudvis.undo",
        "title": "Chudvis: Undo Last Edit"
      }
    ],
    "keybindings": [
      {
        "command": "chudvis.toggle",
        "key": "ctrl+alt+g",
        "mac": "cmd+alt+g"
      }
    ],
    "configuration": {
      "title": "Chudvis",
      "properties": {
        "chudvis.bridge.host": {
          "type": "string",
          "default": "127.0.0.1",
          "description": "Loopback host used by the local Chudvis bridge."
        },
        "chudvis.bridge.port": {
          "type": "number",
          "default": 8765,
          "minimum": 1,
          "maximum": 65535,
          "description": "Loopback port used by the local Chudvis bridge."
        },
        "chudvis.bridge.sessionToken": {
          "type": "string",
          "default": "",
          "scope": "machine",
          "description": "Optional token that must match the Python IDE configuration."
        },
        "chudvis.bridge.maxMessageBytes": {
          "type": "number",
          "default": 262144,
          "minimum": 1024,
          "maximum": 1048576,
          "description": "Maximum accepted bridge notification size."
        },
        "chudvis.agent.command": {
          "type": "string",
          "default": "code",
          "scope": "machine",
          "description": "VS Code CLI executable used only by the explicitly selected legacy provider."
        },
        "chudvis.agent.mode": {
          "type": "string",
          "default": "agent",
          "description": "Agent mode passed only to the explicitly selected legacy VS Code CLI provider."
        },
        "chudvis.provider": {
          "type": "string",
          "enum": [
            "backboard",
            "legacy-vscode-cli"
          ],
          "default": "backboard",
          "description": "Model provider for confirmed local-Whisper fallback requests. Wake-word requests always use the bounded Chudvis flow."
        },
        "chudvis.backboard.editProvider": {
          "type": "string",
          "default": "anthropic",
          "description": "Backboard provider used for code edits. Validated against the Models API."
        },
        "chudvis.backboard.editModel": {
          "type": "string",
          "default": "claude-opus-4-7-20250501",
          "description": "Backboard tool-capable model used for code edits."
        },
        "chudvis.backboard.questionProvider": {
          "type": "string",
          "default": "google",
          "description": "Backboard provider used for stateless questions."
        },
        "chudvis.backboard.questionModel": {
          "type": "string",
          "default": "gemini-3.5-flash",
          "description": "Backboard model used for stateless questions."
        },
        "chudvis.backboard.requestTimeoutMs": {
          "type": "number",
          "default": 60000,
          "minimum": 5000,
          "maximum": 180000,
          "description": "Timeout for each Backboard request."
        },
        "chudvis.edits.maxChangeCharacters": {
          "type": "number",
          "default": 100000,
          "minimum": 1000,
          "maximum": 250000,
          "description": "Maximum combined original and replacement characters in one Chudvis edit."
        },
        "chudvis.runtime.preview": {
          "type": "boolean",
          "default": false,
          "description": "Show the camera landmark preview while IDE controls are running."
        },
        "chudvis.runtime.voice": {
          "type": "boolean",
          "default": true,
          "description": "Enable wake-word voice and the local Whisper fallback in IDE mode."
        },
        "chudvis.runtime.uvExecutable": {
          "type": "string",
          "default": "uv",
          "scope": "machine",
          "description": "Windows-native uv executable or absolute path used by the packaged Python runtime."
        },
        "chudvis.runtime.pythonVersion": {
          "type": "string",
          "default": "3.12",
          "scope": "machine",
          "description": "Python version used for the isolated packaged runtime environment."
        },
        "chudvis.runtime.sourceRoot": {
          "type": "string",
          "default": "",
          "scope": "machine",
          "description": "Optional Chudvis source root override for extension development. Leave empty to use the packaged runtime."
        },
        "chudvis.runtime.extraArguments": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "maxItems": 32,
          "default": [],
          "scope": "machine",
          "description": "Additional direct arguments for calibrate, test, or IDE mode, such as --camera and 1."
        }
      }
    }
  },
  "scripts": {
    "stage-runtime": "node scripts/stage-runtime.mjs",
    "compile": "npm run stage-runtime && tsc -p tsconfig.json",
    "check-types": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --max-warnings=0",
    "format:check": "prettier --check src package.json tsconfig.json eslint.config.mjs",
    "test": "npm run compile && node --test dist/test/*.test.js",
    "package": "npm run compile && vsce package --out chudvis-vscode.vsix",
    "verify": "npm run check-types && npm run lint && npm run format:check && npm test"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/vscode": "^1.95.0",
    "@vscode/vsce": "^3.9.2",
    "eslint": "^9.17.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.18.0"
  }
}
