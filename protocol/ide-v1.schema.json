{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chudvis.local/protocol/ide-v1.schema.json",
  "title": "Chudvis IDE Protocol v1 Notification",
  "type": "object",
  "additionalProperties": false,
  "required": ["jsonrpc", "method", "params"],
  "properties": {
    "jsonrpc": { "const": "2.0" },
    "method": { "type": "string", "minLength": 1, "maxLength": 128 },
    "params": { "type": "object" }
  },
  "$defs": {
    "requestId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "pattern": "^[A-Za-z0-9_-]+$"
    },
    "voiceStateParams": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state"],
      "properties": {
        "state": {
          "enum": [
            "ready",
            "connecting",
            "listening",
            "understanding",
            "editing",
            "speaking",
            "error",
            "paused"
          ]
        },
        "requestId": { "$ref": "#/$defs/requestId" },
        "detail": { "type": "string", "maxLength": 500 }
      }
    },
    "requestParams": {
      "type": "object",
      "required": ["requestId"],
      "properties": {
        "requestId": { "$ref": "#/$defs/requestId" }
      }
    },
    "requestOnlyParams": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requestId"],
      "properties": {
        "requestId": { "$ref": "#/$defs/requestId" }
      }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "method": { "const": "voice.state" } } },
      "then": { "properties": { "params": { "$ref": "#/$defs/voiceStateParams" } } }
    },
    {
      "if": { "properties": { "method": { "const": "voice.partial" } } },
      "then": {
        "properties": {
          "params": {
            "unevaluatedProperties": false,
            "allOf": [
              { "$ref": "#/$defs/requestParams" },
              {
                "type": "object",
                "required": ["text"],
                "properties": { "text": { "type": "string", "maxLength": 16000 } }
              }
            ]
          }
        }
      }
    },
    {
      "if": { "properties": { "method": { "const": "voice.request" } } },
      "then": {
        "properties": {
          "params": {
            "unevaluatedProperties": false,
            "allOf": [
              { "$ref": "#/$defs/requestParams" },
              {
                "type": "object",
                "required": ["transcript"],
                "properties": {
                  "transcript": { "type": "string", "minLength": 1, "maxLength": 16000 }
                }
              }
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": { "method": { "enum": ["edit.approve", "edit.cancel"] } }
      },
      "then": { "properties": { "params": { "$ref": "#/$defs/requestOnlyParams" } } }
    },
    {
      "if": { "properties": { "method": { "const": "voice.cancel" } } },
      "then": {
        "properties": {
          "params": {
            "type": "object",
            "additionalProperties": false,
            "properties": { "requestId": { "$ref": "#/$defs/requestId" } }
          }
        }
      }
    },
    {
      "if": { "properties": { "method": { "const": "voice.complete" } } },
      "then": {
        "properties": {
          "params": {
            "type": "object",
            "additionalProperties": false,
            "required": ["requestId", "status"],
            "properties": {
              "requestId": { "$ref": "#/$defs/requestId" },
              "status": { "enum": ["succeeded", "failed", "cancelled"] },
              "spokenSummary": { "type": "string", "maxLength": 160 }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": { "method": { "const": "edit.approvalRequested" } }
      },
      "then": {
        "properties": {
          "params": {
            "type": "object",
            "additionalProperties": false,
            "required": ["requestId", "files", "changeCount"],
            "properties": {
              "requestId": { "$ref": "#/$defs/requestId" },
              "files": {
                "type": "array",
                "minItems": 1,
                "maxItems": 3,
                "items": { "type": "string", "maxLength": 500 }
              },
              "changeCount": { "type": "integer", "minimum": 1, "maximum": 100 }
            }
          }
        }
      }
    }
  ]
}
